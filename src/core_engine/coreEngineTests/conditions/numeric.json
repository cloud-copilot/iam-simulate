[
  {
    "name": "NumericGreaterThan: request value greater than policy value allows",
    "request": {
      "action": "s3:ListBucket",
      "resource": {
        "resource": "arn:aws:s3:::my-bucket",
        "accountId": "123456789012"
      },
      "principal": "arn:aws:iam::123456789012:user/test-user",
      "context": {
        "aws:MultiFactorAuthAge": "15"
      }
    },
    "identityPolicies": [
      {
        "Version": "2012-10-17",
        "Statement": [
          {
            "Effect": "Allow",
            "Action": "*",
            "Resource": "*",
            "Condition": {
              "NumericGreaterThan": {
                "aws:MultiFactorAuthAge": "10"
              }
            }
          }
        ]
      }
    ],
    "expected": {
      "response": "Allowed"
    }
  },
