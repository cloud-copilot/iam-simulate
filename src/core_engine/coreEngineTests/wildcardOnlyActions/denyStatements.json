[
  {
    "name": "wildcard only action: Deny/Resource with * denies access",
    "request": {
      "action": "s3:ListAllMyBuckets",
      "resource": {
        "resource": "*",
        "accountId": "123456789012"
      },
      "principal": "arn:aws:iam::123456789012:user/test-user",
      "wildcardOnlyAction": true
    },
    "identityPolicies": [
      {
        "Version": "2012-10-17",
        "Statement": [
          {
            "Effect": "Allow",
            "Action": "s3:ListAllMyBuckets",
            "Resource": "*"
          },
          {
            "Effect": "Deny",
            "Action": "s3:ListAllMyBuckets",
            "Resource": "*"
          }
        ]
      }
    ],
    "expected": {
      "response": "ExplicitlyDenied"
    }
  },
  {
    "name": "wildcard only action: Deny/Resource with specific ARN does not deny access",
    "request": {
      "action": "s3:ListAllMyBuckets",
      "resource": {
        "resource": "*",
        "accountId": "123456789012"
      },
      "principal": "arn:aws:iam::123456789012:user/test-user",
      "wildcardOnlyAction": true
    },
    "identityPolicies": [
      {
        "Version": "2012-10-17",
        "Statement": [
          {
            "Effect": "Allow",
            "Action": "s3:ListAllMyBuckets",
            "Resource": "*"
          },
          {
            "Effect": "Deny",
            "Action": "s3:ListAllMyBuckets",
            "Resource": "arn:aws:s3:::my-bucket"
          }
        ]
      }
    ],
    "expected": {
      "response": "Allowed"
    }
  },
  {
    "name": "wildcard only action: Deny/NotResource with specific ARN denies access",
    "request": {
      "action": "s3:ListAllMyBuckets",
      "resource": {
        "resource": "*",
        "accountId": "123456789012"
      },
      "principal": "arn:aws:iam::123456789012:user/test-user",
      "wildcardOnlyAction": true
    },
    "identityPolicies": [
      {
        "Version": "2012-10-17",
        "Statement": [
          {
            "Effect": "Allow",
            "Action": "s3:ListAllMyBuckets",
            "Resource": "*"
          },
          {
            "Effect": "Deny",
            "Action": "s3:ListAllMyBuckets",
            "NotResource": "arn:aws:s3:::my-bucket"
          }
        ]
      }
    ],
    "expected": {
      "response": "ExplicitlyDenied"
    }
  },
  {
    "name": "wildcard only action: Deny/NotResource with * does not deny access",
    "request": {
      "action": "s3:ListAllMyBuckets",
      "resource": {
        "resource": "*",
        "accountId": "123456789012"
      },
      "principal": "arn:aws:iam::123456789012:user/test-user",
      "wildcardOnlyAction": true
    },
    "identityPolicies": [
      {
        "Version": "2012-10-17",
        "Statement": [
          {
            "Effect": "Allow",
            "Action": "s3:ListAllMyBuckets",
            "Resource": "*"
          },
          {
            "Effect": "Deny",
            "Action": "s3:ListAllMyBuckets",
            "NotResource": "*"
          }
        ]
      }
    ],
    "expected": {
      "response": "Allowed"
    }
  }
]
