[
  {
    "name": "wildcard only action with a specific resource ARN does not grant access",
    "request": {
      "action": "s3:ListAllMyBuckets",
      "resource": {
        "resource": "*",
        "accountId": "123456789012"
      },
      "principal": "arn:aws:iam::123456789012:user/test-user",
      "wildcardOnlyAction": true
    },
    "identityPolicies": [
      {
        "Version": "2012-10-17",
        "Statement": [
          {
            "Effect": "Allow",
            "Action": "s3:ListAllMyBuckets",
            "Resource": "arn:aws:s3:::my-bucket"
          }
        ]
      }
    ],
    "expected": {
      "response": "ImplicitlyDenied"
    }
  },
  {
    "name": "wildcard only action with a wildcard resource ARN does grant access",
    "request": {
      "action": "s3:ListAllMyBuckets",
      "resource": {
        "resource": "*",
        "accountId": "123456789012"
      },
      "principal": "arn:aws:iam::123456789012:user/test-user",
      "wildcardOnlyAction": true
    },
    "identityPolicies": [
      {
        "Version": "2012-10-17",
        "Statement": [
          {
            "Effect": "Allow",
            "Action": "s3:ListAllMyBuckets",
            "Resource": "*"
          }
        ]
      }
    ],
    "expected": {
      "response": "Allowed"
    }
  }
]
