[
  {
    "name": "Allow action with comma does not match the request action",
    "request": {
      "action": "s3:GetObject",
      "resource": {
        "resource": "arn:aws:s3:::my-bucket/object",
        "accountId": "123456789012"
      },
      "principal": "arn:aws:iam::123456789012:user/test-user",
      "context": {}
    },
    "identityPolicies": [
      {
        "Version": "2012-10-17",
        "Statement": [
          {
            "Effect": "Allow",
            "Action": "s3:GetObject,PutObject",
            "Resource": "*"
          }
        ]
      }
    ],
    "expected": {
      "response": "ImplicitlyDenied"
    }
  },
  {
    "name": "Allow action with comma does not match the action after the comma",
    "request": {
      "action": "s3:PutObject",
      "resource": {
        "resource": "arn:aws:s3:::my-bucket/object",
        "accountId": "123456789012"
      },
      "principal": "arn:aws:iam::123456789012:user/test-user",
      "context": {}
    },
    "identityPolicies": [
      {
        "Version": "2012-10-17",
        "Statement": [
          {
            "Effect": "Allow",
            "Action": "s3:GetObject,PutObject",
            "Resource": "*"
          }
        ]
      }
    ],
    "expected": {
      "response": "ImplicitlyDenied"
    }
  },
  {
    "name": "Deny action with comma does not match, so an Allow still applies",
    "request": {
      "action": "s3:GetObject",
      "resource": {
        "resource": "arn:aws:s3:::my-bucket/object",
        "accountId": "123456789012"
      },
      "principal": "arn:aws:iam::123456789012:user/test-user",
      "context": {}
    },
    "identityPolicies": [
      {
        "Version": "2012-10-17",
        "Statement": [
          {
            "Effect": "Allow",
            "Action": "s3:*",
            "Resource": "*"
          },
          {
            "Effect": "Deny",
            "Action": "s3:GetObject,PutObject",
            "Resource": "*"
          }
        ]
      }
    ],
    "expected": {
      "response": "Allowed"
    }
  },
  {
    "name": "Array of actions: comma-containing action does not match, but a separate valid action does",
    "request": {
      "action": "s3:GetObject",
      "resource": {
        "resource": "arn:aws:s3:::my-bucket/object",
        "accountId": "123456789012"
      },
      "principal": "arn:aws:iam::123456789012:user/test-user",
      "context": {}
    },
    "identityPolicies": [
      {
        "Version": "2012-10-17",
        "Statement": [
          {
            "Effect": "Allow",
            "Action": ["s3:GetObject,PutObject", "s3:GetObject"],
            "Resource": "*"
          }
        ]
      }
    ],
    "expected": {
      "response": "Allowed"
    }
  },
  {
    "name": "Allow action with comma and wildcards does not match the request action",
    "request": {
      "action": "s3:GetObject",
      "resource": {
        "resource": "arn:aws:s3:::my-bucket/object",
        "accountId": "123456789012"
      },
      "principal": "arn:aws:iam::123456789012:user/test-user",
      "context": {}
    },
    "identityPolicies": [
      {
        "Version": "2012-10-17",
        "Statement": [
          {
            "Effect": "Allow",
            "Action": "s3:Get*,Put*",
            "Resource": "*"
          }
        ]
      }
    ],
    "expected": {
      "response": "ImplicitlyDenied"
    }
  },
  {
    "name": "Allow action with trailing comma does not match the request action",
    "request": {
      "action": "s3:GetObject",
      "resource": {
        "resource": "arn:aws:s3:::my-bucket/object",
        "accountId": "123456789012"
      },
      "principal": "arn:aws:iam::123456789012:user/test-user",
      "context": {}
    },
    "identityPolicies": [
      {
        "Version": "2012-10-17",
        "Statement": [
          {
            "Effect": "Allow",
            "Action": "s3:GetObject,",
            "Resource": "*"
          }
        ]
      }
    ],
    "expected": {
      "response": "ImplicitlyDenied"
    }
  }
]
