[
  {
    "name": "Statement without Principal never matches (Allow)",
    "request": {
      "action": "s3:GetObject",
      "resource": {
        "resource": "arn:aws:s3:::mybucket/testobject",
        "accountId": "123456789012"
      },
      "principal": "arn:aws:iam::123456789012:user/test-user",
      "context": {}
    },
    "identityPolicies": [],
    "resourcePolicy": {
      "Version": "2012-10-17",
      "Statement": [
        {
          "Effect": "Allow",
          "Action": "s3:GetObject",
          "Resource": "arn:aws:s3:::mybucket/testobject"
        }
      ]
    },
    "expected": {
      "response": "ImplicitlyDenied"
    }
  },
  {
    "name": "Statement without Principal does not deny when identity allows",
    "request": {
      "action": "s3:GetObject",
      "resource": {
        "resource": "arn:aws:s3:::mybucket/testobject",
        "accountId": "123456789012"
      },
      "principal": "arn:aws:iam::123456789012:user/test-user",
      "context": {}
    },
    "identityPolicies": [
      {
        "Version": "2012-10-17",
        "Statement": [
          {
            "Effect": "Allow",
            "Action": "s3:GetObject",
            "Resource": "arn:aws:s3:::mybucket/testobject"
          }
        ]
      }
    ],
    "resourcePolicy": {
      "Version": "2012-10-17",
      "Statement": [
        {
          "Effect": "Deny",
          "Action": "s3:GetObject",
          "Resource": "arn:aws:s3:::mybucket/testobject"
        }
      ]
    },
    "expected": {
      "response": "Allowed"
    }
  },
  {
    "name": "Statement without Principal is skipped; sibling statement still applies",
    "request": {
      "action": "s3:GetObject",
      "resource": {
        "resource": "arn:aws:s3:::mybucket/testobject",
        "accountId": "123456789012"
      },
      "principal": "arn:aws:iam::123456789012:user/test-user",
      "context": {}
    },
    "identityPolicies": [],
    "resourcePolicy": {
      "Version": "2012-10-17",
      "Statement": [
        {
          "Effect": "Allow",
          "Action": "s3:GetObject",
          "Resource": "arn:aws:s3:::mybucket/testobject"
        },
        {
          "Effect": "Allow",
          "Action": "s3:GetObject",
          "Resource": "arn:aws:s3:::mybucket/testobject",
          "Principal": "*"
        }
      ]
    },
    "expected": {
      "response": "Allowed"
    }
  }
]
