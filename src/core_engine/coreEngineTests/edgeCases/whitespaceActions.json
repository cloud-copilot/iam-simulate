    },
    "identityPolicies": [
      {
        "Version": "2012-10-17",
        "Statement": [
          {
            "Effect": "Allow",
            "Action": "s3:      ",
            "Resource": "*"
          }
        ]
      }
    ],
    "expected": {
      "response": "ImplicitlyDenied"
    }
  },
  {
