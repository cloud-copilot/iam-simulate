[
  {
    "name": "short ARN arn:aws:sqs (3 seg) expands and matches wildcard request",
    "simulation": {
      "identityPolicies": [
        {
          "name": "short-arn-policy",
          "policy": {
            "Version": "2012-10-17",
            "Statement": [
              {
                "Effect": "Allow",
                "Action": "sqs:SendMessage",
                "Resource": "arn:aws:sqs"
              }
            ]
          }
        }
      ],
      "serviceControlPolicies": [],
      "resourceControlPolicies": [],
      "resourcePolicy": null,
      "request": {
        "action": "sqs:SendMessage",
        "resource": {
          "resource": "*",
          "accountId": "111111111111"
        },
        "principal": "arn:aws:iam::111111111111:user/Alice",
        "contextVariables": {}
      }
    },
    "expected": {
      "resultType": "wildcard",
      "results": [
        {
          "resourceType": "queue",
          "resourcePattern": "arn:aws:sqs",
          "result": "Allowed"
        }
      ],
      "overallResult": "Allowed"
    }
  },
